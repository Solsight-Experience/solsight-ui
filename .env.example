# Environment Variables for FlaxH Trade UI

# API Configuration
API_ORIGIN=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3000
NEXT_PUBLIC_SOCKET_URL=http://localhost:3000

# Solana Network Configuration
NEXT_PUBLIC_SOLANA_NETWORK=mainnet-beta
NEXT_PUBLIC_SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
NEXT_PUBLIC_SOLANA_DEVNET_RPC_URL=https://api.devnet.solana.com

# Feature Flags
NEXT_PUBLIC_ENABLE_DEV_TOOLS=true
NEXT_PUBLIC_ENABLE_MOCK=false

# App Configuration
NEXT_PUBLIC_APP_NAME="FlaxH Trade"
NEXT_PUBLIC_APP_DESCRIPTION="Decentralized Solana Token Transfer Platform"

# OAuth Configuration
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
