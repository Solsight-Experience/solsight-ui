# Environment Variables for FlaxH Trade UI

# API Configuration
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_SOCKET_URL=http://localhost:3000

# Solana Network Configuration
NEXT_PUBLIC_SOLANA_NETWORK=devnet

# Feature Flags
NEXT_PUBLIC_ENABLE_DEV_TOOLS=true

# App Configuration
NEXT_PUBLIC_APP_NAME="FlaxH Trade"
NEXT_PUBLIC_APP_DESCRIPTION="Decentralized Solana Token Transfer Platform"

# OAuth Configuration
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# Mock data
NEXT_PUBLIC_ENABLE_MOCK=true

NEXT_PUBLIC_JUPITER_QUOTE_URL=
NEXT_PUBLIC_JUPITER_API_KEY=